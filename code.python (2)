async def button_callback(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Handle inline button presses."""
    query = update.callback_query
    await query.answer()
    
    user_id = update.effective_user.id
    
    # Check channel membership
    is_member = await check_channel_membership(user_id, context)
    if not is_member:
        keyboard = [[InlineKeyboardButton("📢 Join Channel", url=REQUIRED_CHANNEL_LINK)]]
        reply_markup = InlineKeyboardMarkup(keyboard)
        await query.edit_message_text(
            "❌ **You left the channel!**\n\n"
            f"Please re-join: {REQUIRED_CHANNEL_LINK}",
            reply_markup=reply_markup,
            parse_mode="Markdown"
        )
        return
    
    data = query.data
    
    if data.startswith("server_"):
        server_key = data.replace("server_", "")
        if server_key in SERVERS:
            server = SERVERS[server_key]
            
            user_sessions[user_id] = {
                "server": server_key,
                "step": "awaiting_credentials"
            }
            
            await query.edit_message_text(
                f"✅ **You selected:** {server['flag']} {server['name']}\n\n"
                f"**📝 Now send me your credentials** from [hackkach.com](https://hackkach.com)\n\n"
                f"**Format:**\n"
                f"`username password`\n\n"
                f"_(Separate with a space)_\n\n"
                f"**Example:**\n"
                f"`john_doe MySecurePass123`",
                parse_mode="Markdown",
                disable_web_page_preview=True
            )


async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Handle text messages from users."""
    user_id = update.effective_user.id
    text = update.message.text.strip()
    
    logger.info(f"Message from {user_id}: {text[:30]}...")
    
    # Check channel membership
    is_member = await check_channel_membership(user_id, context)
    if not is_member:
        keyboard = [[InlineKeyboardButton("📢 Join Channel", url=REQUIRED_CHANNEL_LINK)]]
        reply_markup = InlineKeyboardMarkup(keyboard)
        await update.message.reply_text(
            f"❌ **You must join our channel first!**\n\n"
            f"Join: {REQUIRED_CHANNEL_LINK}",
            reply_markup=reply_markup,
            parse_mode="Markdown"
        )
        return
    
    # Check if user has a session
    if user_id not in user_sessions or user_sessions[user_id].get("step") != "awaiting_credentials":
        keyboard = [
            [
                InlineKeyboardButton("🇬🇧 UK Server", callback_data="server_uk"),
                InlineKeyboardButton("🇩🇪 Germany", callback_data="server_germany"),
            ]
        ]
        reply_markup = InlineKeyboardMarkup(keyboard)
        await update.message.reply_text(
            "Please **select a server first** using the buttons below:",
            reply_markup=reply_markup,
            parse_mode="Markdown"
        )
        return
    
    # Parse credentials (format: "username password")
    parts = text.split(maxsplit=1)
    if len(parts) != 2:
        await update.message.reply_text(
            "❌ **Invalid format!**\n\n"
            "Please send your credentials as:\n"
            "`username password`\n\n"
            "_(Separate username and password with a space)_",
            parse_mode="Markdown"
        )
        return
    
    username, password = parts[0].strip(), parts[1].strip()
    
    # Send "processing" message
    processing_msg = await update.message.reply_text(
        "🔄 **Validating credentials...**\n"
        "Please wait...",
        parse_mode="Markdown"
    )
    
    # Validate credentials
    is_valid = await validate_hackkach_credentials(username, password)
    
    if not is_valid:
        await processing_msg.edit_text(
            "❌ **Invalid credentials!**\n\n"
            "Please check your username and password from [hackkach.com](https://hackkach.com)\n"
            "and try again.\n\n"
            "Format: `username password`",
            parse_mode="Markdown",
            disable_web_page_preview=True
        )
        return
    
    # Credentials valid - generate config
    await processing_msg.edit_text(
        "✅ **Credentials valid!**\n"
        "🔄 **Generating your SLIPNET config...**",
        parse_mode="Markdown"
    )
    
    server_key = user_sessions[user_id]["server"]
    
    # Build the config
    config = build_slipnet_config(server_key, username, password)
    
    # Generate the import text
    config_text = config_to_import_text(config, server_key, username, password)
    
    # Send the config text
    await processing_msg.delete()
    
    await update.message.reply_text(
        config_text,
        parse_mode="Markdown",
        disable_web_page_preview=True
    )
    
    # Also send the JSON as a file for easy import
    json_bytes = json.dumps(config, indent=2).encode()
    await update.message.reply_document(
        document=InputFile(BytesIO(json_bytes), filename=f"slipnet_{server_key}_{username}.json"),
        caption=f"📁 **SLIPNET Config - {SERVERS[server_key]['name']}**\n"
                f"👤 User: `{username}`\n"
                f"💾 Save this file and import in SlipNet app\n"
                f"━━━━━━━━━━━━━━━━\n"
                f"🔰 {REQUIRED_CHANNEL}",
        parse_mode="Markdown"
    )
    
    # Cleanup session
    if user_id in user_sessions:
        del user_sessions[user_id]
    
    logger.info(f"Config generated for {username} on {server_key}")


